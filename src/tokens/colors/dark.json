  "semantic": {
    "text": {
      "primary": {
        "$extensions": {
          "com.figma.scopes": [
            "SHAPE_FILL",
            "TEXT_FILL"
          ],
          "com.figma.hiddenFromPublishing": false
        },
        "$type": "color",
        "$value": "{parent.gray.950}",
        "$description": "titles, subtitles, actions, etc"
      },
      "secondary": {
        "$extensions": {
          "com.figma.scopes": [
            "SHAPE_FILL",
            "TEXT_FILL"
          ],
          "com.figma.hiddenFromPublishing": false
        },
        "$type": "color",
        "$value": "{parent.gray.600}",
        "$description": "most of the support text. usual pairing: primary for title/subtitle, secondary for support text/further explanation"
      },
      "pale": {
        "$extensions": {
          "com.figma.scopes": [
            "SHAPE_FILL",
            "TEXT_FILL"
          ],
          "com.figma.hiddenFromPublishing": false
        },
        "$type": "color",
        "$value": "{parent.gray.350}",
        "$description": "for icons and text that don't need attention"
      },
      "inverse": {
        "$extensions": {
          "com.figma.scopes": [
            "SHAPE_FILL",
            "TEXT_FILL"
          ],
          "com.figma.hiddenFromPublishing": false
        },
        "$type": "color",
        "$value": "{parent.gray.00}",
